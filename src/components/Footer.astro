---
import { t, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<footer class="border-t border-white/5 mt-16">
  <div class="max-w-6xl mx-auto px-6 py-14 grid md:grid-cols-3 gap-10">
    <div>
      <h4 class="text-sm font-semibold text-mochi-text mb-3">{s.footer.links_title}</h4>
      <ul class="space-y-2 text-sm text-mochi-muted">
        {s.footer.links.map((l) => (
          <li><a class="hover:text-mochi-text" href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h4 class="text-sm font-semibold text-mochi-text mb-3">{s.footer.community_title}</h4>
      <ul class="space-y-2 text-sm text-mochi-muted">
        {s.footer.community.map((l) => (
          <li><a class="hover:text-mochi-text" href={l.href} rel="noopener">{l.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h4 class="text-sm font-semibold text-mochi-text mb-3">{s.footer.legal_title}</h4>
      <ul class="space-y-2 text-sm text-mochi-muted">
        {s.footer.legal.map((l) => (
          <li><a class="hover:text-mochi-text" href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="text-center text-xs text-mochi-muted py-6 border-t border-white/5">
    {s.footer.bottom}
  </div>
</footer>
