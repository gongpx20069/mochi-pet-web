---
import { t, type Lang } from '../../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<section id="sleep" class="section pt-0">
  <div class="rounded-3xl border border-indigo-400/30 bg-gradient-to-br from-indigo-950/80 via-violet-900/40 to-[#160a1d]/80 p-8 md:p-10 flex flex-col md:flex-row md:items-center gap-6">
    <div class="text-5xl md:text-6xl select-none">🌙</div>
    <div class="flex-1">
      <span class="eyebrow !text-indigo-200/90">{s.sleep.eyebrow}</span>
      <h3 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight">{s.sleep.h2}</h3>
      <p class="mt-3 text-mochi-text/90 leading-relaxed max-w-2xl">{s.sleep.body}</p>
    </div>
    <span class="shrink-0 self-start md:self-center inline-flex items-center rounded-full border border-indigo-300/40 bg-indigo-400/10 px-3 py-1 text-xs font-mono text-indigo-200">
      {s.sleep.tag}
    </span>
  </div>
</section>
