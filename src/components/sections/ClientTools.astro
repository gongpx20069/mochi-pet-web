---
import { t, type Lang } from '../../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<section id="tools" class="section">
  <h2 class="h2 text-center">{s.tools.h2}</h2>
  <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
    {s.tools.items.map((it) => (
      <div class="card flex flex-col items-center text-center hover:border-mochi-purple/40 transition-colors">
        <div class="text-3xl">{it.icon}</div>
        <p class="mt-3 text-sm">{it.title}</p>
      </div>
    ))}
  </div>
  <p class="mt-8 text-center text-sm text-mochi-muted">{s.tools.foot}</p>
</section>
