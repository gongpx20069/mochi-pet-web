---
import { t, type Lang } from '../../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<section id="whatmochi" class="section">
  <h2 class="h2 text-center"><span class="gradient-text">{s.whatmochi.h2}</span></h2>
  <p class="mt-4 text-center text-mochi-muted max-w-2xl mx-auto">{s.whatmochi.sub}</p>

  <!-- Tier A: core capabilities (heavier cards, gradient borders) -->
  <h3 class="mt-14 text-xs uppercase tracking-widest text-mochi-pink/90 font-semibold text-center">{s.whatmochi.tier_a_label}</h3>
  <div class="mt-6 grid md:grid-cols-2 gap-6">
    {s.whatmochi.tier_a.map((it) => (
      <div class="tier-a-card group">
        <div class="tier-a-inner">
          <div class="text-4xl">{it.icon}</div>
          <h4 class="mt-4 text-xl font-bold tracking-tight">{it.title}</h4>
          <p class="mt-3 text-sm text-mochi-muted leading-relaxed">{it.body}</p>
        </div>
      </div>
    ))}
  </div>

  <!-- Tier B: small action cards -->
  <h3 class="mt-16 text-xs uppercase tracking-widest text-mochi-purple/90 font-semibold text-center">{s.whatmochi.tier_b_label}</h3>
  <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3">
    {s.whatmochi.tier_b.map((it) => (
      <div class="card flex flex-col items-center text-center !p-4 hover:border-mochi-purple/40 transition-colors">
        <div class="text-2xl">{it.icon}</div>
        <p class="mt-2 text-xs md:text-sm">{it.title}</p>
      </div>
    ))}
  </div>

  <p class="mt-8 text-center text-sm text-mochi-muted">{s.whatmochi.foot}</p>
</section>

<style>
  .tier-a-card {
    position: relative;
    border-radius: 1.25rem;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,107,157,0.55), rgba(192,132,252,0.55));
    transition: transform 0.2s ease;
  }
  .tier-a-card:hover { transform: translateY(-2px); }
  .tier-a-inner {
    border-radius: calc(1.25rem - 1px);
    background: linear-gradient(160deg, rgba(26,26,46,0.92), rgba(22,10,29,0.92));
    padding: 1.75rem;
    height: 100%;
  }
</style>
