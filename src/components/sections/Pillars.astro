---
import { t, type Lang } from '../../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<section id="pillars" class="section">
  <h2 class="h2 text-center"><span class="gradient-text">{s.pillars.h2}</span></h2>
  <div class="mt-12 grid md:grid-cols-3 gap-6">
    {s.pillars.items.map((it) => (
      <div class="card hover:border-mochi-pink/30 transition-colors">
        <div class="text-3xl">{it.icon}</div>
        <h3 class="mt-3 text-lg font-semibold">{it.title}</h3>
        <p class="mt-2 text-sm text-mochi-muted leading-relaxed">{it.body}</p>
      </div>
    ))}
  </div>
</section>
