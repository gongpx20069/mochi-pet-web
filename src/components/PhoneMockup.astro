---
interface Props {
  expression?: 'happy' | 'excited' | 'sleepy' | 'sad' | 'angry' | 'neutral';
}
const { expression = 'happy' } = Astro.props;
const base = import.meta.env.BASE_URL;
const faceUrl = `${base}emotions/${expression}.svg`.replace(/\/+/g, '/');
---
<div class="phone-mockup relative mx-auto w-full max-w-md aspect-[16/10]">
  <!-- Phone shell (landscape) -->
  <div class="phone-shell absolute inset-0 rounded-[2.2rem] bg-[#111122] border border-white/10 shadow-2xl shadow-black/60 p-2.5">
    <!-- Left side bar (camera dot) -->
    <span class="phone-left-bar absolute left-3 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-white/20"></span>
    <!-- Right side bar (speaker slot) -->
    <span class="phone-right-bar absolute right-2 top-1/2 -translate-y-1/2 w-12 h-1 rounded-full bg-white/10"></span>

    <div class="phone-screen relative h-full w-full rounded-[1.6rem] bg-black overflow-hidden">
      <img
        id="mochi-face"
        src={faceUrl}
        alt="Mochi"
        class="mochi-face w-full h-full object-cover select-none pointer-events-none"
        data-base={base}
      />
      <div class="glass-overlay absolute inset-0 pointer-events-none bg-gradient-to-br from-white/[0.06] via-transparent to-white/[0.03]"></div>
    </div>
  </div>

  <!-- Floating sleep "💤" hint above the phone -->
  <span class="floating-zzz absolute left-[14%] -top-2 text-mochi-purple/80 text-2xl select-none">💤</span>
</div>

<style>
  .mochi-face {
    transform-origin: center;
    animation: mochi-bob 3s ease-in-out infinite;
    transition: opacity 400ms ease;
  }
  @keyframes mochi-bob {
    0%, 100% { transform: translateY(-3px); }
    50%      { transform: translateY(3px); }
  }

  .floating-zzz {
    animation: floating-zzz 8s ease-in-out infinite;
    opacity: 0;
  }
  @keyframes floating-zzz {
    0%, 70%, 100% { opacity: 0; transform: translateY(0); }
    20%           { opacity: 0.9; transform: translateY(-6px); }
    40%           { opacity: 0.5; transform: translateY(-12px); }
    55%           { opacity: 0; transform: translateY(-18px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mochi-face, .floating-zzz { animation: none; }
  }
</style>

<script>
  const face = document.getElementById('mochi-face') as HTMLImageElement | null;
  if (face) {
    const base = face.dataset.base || '/';
    const join = (p: string) => `${base}${p}`.replace(/\/+/g, '/');
    const cycle = [
      join('emotions/happy.svg'),
      join('emotions/excited.svg'),
      join('emotions/happy.svg'),
      join('emotions/sleepy.svg'),
    ];
    // Preload to avoid flicker between swaps
    cycle.forEach((src) => { const i = new Image(); i.src = src; });
    let i = 0;
    setInterval(() => {
      i = (i + 1) % cycle.length;
      face.src = cycle[i];
    }, 6000);
  }
</script>
