---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/sections/Hero.astro';
import WhatMochiCanDo from '../../components/sections/WhatMochiCanDo.astro';
import HowYouUseIt from '../../components/sections/HowYouUseIt.astro';
import BYOK from '../../components/sections/BYOK.astro';
import SleepTeaser from '../../components/sections/SleepTeaser.astro';
import Roadmap from '../../components/sections/Roadmap.astro';
import Waitlist from '../../components/sections/Waitlist.astro';
const lang = 'ja' as const;
---
<Layout lang={lang}>
  <Nav lang={lang} />
  <main class="flex-1">
    <Hero lang={lang} />
    <WhatMochiCanDo lang={lang} />
    <HowYouUseIt lang={lang} />
    <BYOK lang={lang} />
    <SleepTeaser lang={lang} />
    <Roadmap lang={lang} />
    <Waitlist lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
