---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Pillars from '../components/sections/Pillars.astro';
import HowYouUseIt from '../components/sections/HowYouUseIt.astro';
import BYOK from '../components/sections/BYOK.astro';
import ClientTools from '../components/sections/ClientTools.astro';
import Roadmap from '../components/sections/Roadmap.astro';
import Waitlist from '../components/sections/Waitlist.astro';
const lang = 'zh' as const;
---
<Layout lang={lang}>
  <Nav lang={lang} />
  <main class="flex-1">
    <Hero lang={lang} />
    <Pillars lang={lang} />
    <HowYouUseIt lang={lang} />
    <BYOK lang={lang} />
    <ClientTools lang={lang} />
    <Roadmap lang={lang} />
    <Waitlist lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
